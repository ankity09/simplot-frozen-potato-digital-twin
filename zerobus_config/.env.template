# Zerobus Station Configuration
# Copy this file to .env and fill in your values

# Service Principal credentials (workspace admin required to create)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# Databricks workspace URL (everything before /o=XXXXX)
WORKSPACE_URL=https://fe-sandbox-serverless-lakebase.cloud.databricks.com

# Zerobus ingest URL (workspace_id.ingest.cloud.databricks.com)
ZEROBUS_URL=your_zerobus_url

# Target table
BRONZE_TABLE=ankit_yadav.frozen_potato.potato_sensor_bronze
